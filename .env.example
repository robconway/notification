# Copy this to .env for local testing.  Never commit .env.

# SMTP (Gmail example – use an App Password, not your login password)
# Gmail: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAIL_FROM=your.sending.address@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
EMAIL_TO=rob@medberry.co.uk

# Optional: North Devon citizen portal login (my.northdevon.gov.uk)
# Only needed if the weekly report viewer requires you to be logged in.
# PORTAL_USERNAME=rob@medberry.co.uk
# PORTAL_PASSWORD=your-portal-password

# Optional overrides
# RADIUS_MILES=1
