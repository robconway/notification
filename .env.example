# Copy this file to .env and fill in your values.
# Never commit .env to the repository.

# SMTP server (Gmail example shown)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Sending address and its app-password (not your normal Gmail password).
# For Gmail: Google Account → Security → 2-Step Verification → App passwords
EMAIL_FROM=your.sending.address@gmail.com
EMAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to send the alert (defaults to rob@medberry.co.uk if unset)
EMAIL_TO=rob@medberry.co.uk

# Optional overrides
# RADIUS_MILES=1
# PLANNING_BASE=https://planning.northdevon.gov.uk
